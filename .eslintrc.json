{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "cypress/globals": true
  },
  "extends": ["react-app", "dicodingacademy", "plugin:cypress/recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["react", "cypress"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "quotes": "off",
    "linebreak-style": "off",
    // "prettier/prettier": "error",

    "react/react-in-jsx-scope": "off",
    "react/jsx-uses-react": "off",

    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn"
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "overrides": [
    {
      "files": ["cypress/**/*.js"],
      "rules": {
        "no-unused-expressions": "off"
      }
    }
  ]
}
